<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>1Space ECDMS API Showcase</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* --- CSS Variables for Easy Theming --- */
        :root {
            --dark-blue-bg: #0d1117;
            --card-bg: rgba(22, 27, 34, 0.7);
            --border-color: rgba(255, 255, 255, 0.1);
            --primary-accent: #58a6ff;
            --secondary-accent: #1f6feb;
            --text-primary: #c9d1d9;
            --text-secondary: #8b949e;
            --button-shadow: 0 4px 15px rgba(88, 166, 255, 0.2);
        }

        /* --- Base Styles --- */
        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--dark-blue-bg);
            background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 20px 20px;
            color: var(--text-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 2rem;
            box-sizing: border-box;
        }

        /* --- Main Card/Showcase Component --- */
        .api-showcase {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2.5rem 3rem;
            max-width: 800px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px); /* For Safari */
            animation: fadeInUp 0.8s ease-out;
        }

        /* --- Header Section --- */
        .api-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .api-icon {
            width: 48px;
            height: 48px;
            color: var(--primary-accent);
        }

        .api-title {
            font-size: 2.75rem;
            font-weight: 700;
            letter-spacing: -1px;
            background: linear-gradient(90deg, var(--primary-accent), #a371f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        /* --- Content Typography --- */
        .api-description {
            font-size: 1.1rem;
            line-height: 1.7;
            color: var(--text-secondary);
            margin-bottom: 2rem;
        }

        .api-showcase hr {
            border: 0;
            height: 1px;
            background: var(--border-color);
            margin: 2rem 0;
        }
        
        .api-footer-text {
             font-size: 0.9rem;
             color: var(--text-secondary);
        }

        /* --- Buttons & Links --- */
        .api-links {
            margin-top: 2rem;
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .btn {
            display: inline-block;
            padding: 12px 28px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background-color: var(--primary-accent);
            color: var(--dark-blue-bg);
            box-shadow: var(--button-shadow);
        }
        
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(88, 166, 255, 0.3);
        }
        
        .btn-secondary {
            background-color: transparent;
            color: var(--primary-accent);
            border: 2px solid var(--border-color);
        }

        .btn-secondary:hover {
            background-color: var(--primary-accent);
            color: var(--dark-blue-bg);
            border-color: var(--primary-accent);
        }

        /* --- Animation --- */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="api-showcase">
        <div class="api-header">
            <svg class="api-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
            <h1 class="api-title">1Space ECDMS API</h1>
        </div>
        
        <p class="api-description">
            Welcome to the 1Space Enterprise Content & Data Management System API. This platform provides secure, scalable endpoints for managing brands, items, and critical business data.
        </p>
        
        <p class="api-footer-text">
            Designed for seamless enterprise integration, it supports robust authentication, validation, and high performance.
        </p>

        <hr>

        <div class="api-links">
            <a href="#" class="btn btn-primary">View Docs</a>
            <a href="#" class="btn btn-secondary">Get API Key</a>
        </div>
    </div>

</body>
</html>