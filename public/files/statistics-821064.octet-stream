 /STATISTICS=STDDEV MINIMUM MAXIMUM MEAN MEDIAN MODE
 /PIECHART FREQ
 /ORDER=ANALYSIS.
DESCRIPTIVES VARIABLES=Age
 /STATISTICS=MEAN STDDEV MIN MAX SEMEAN.
CROSSTABS
 /TABLES=agegroup BY newincome
 /FORMAT=AVALUE TABLES
 /STATISTICS=CHISQ
 /CELLS=COUNT ROW COLUMN
 /COUNT ROUND CELL
 /BARCHART.
CROSSTABS
 /TABLES=agegroup BY newincome BY Edu.Sta
 /FORMAT=AVALUE TABLES
 /STATISTICS=CHISQ
 /CELLS=COUNT ROW COLUMN
 /COUNT ROUND CELL
 /BARCHART.
CROSSTABS
 /TABLES=Mar.Sta BY Edu.Sta
 /FORMAT=AVALUE TABLES
 /STATISTICS=CHISQ
 /CELLS=COUNT ROW COLUMN
 /COUNT ROUND CELL.
SORT CASES  BY Gender.
SPLIT FILE LAYERED BY Gender.
FREQUENCIES VARIABLES=newincome
 /STATISTICS=STDDEV MINIMUM MAXIMUM MEAN MEDIAN
 /PIECHART FREQ
 /ORDER=ANALYSIS.
FREQUENCIES VARIABLES=Mon.Inco
 /STATISTICS=MEAN MEDIAN
 /PIECHART FREQ
 /ORDER=ANALYSIS.
SPLIT FILE OFF.
SORT CASES BY ID(A).
SPLIT FILE OFF.
SORT CASES BY ID(A).
COMPUTE MeanGD2=MEAN(GD2.1,GD2.2,GD2.3,GD2.4,GD2.5).
EXECUTE.
DESCRIPTIVES VARIABLES=Age GPoG1.1 GPoG1.2 GPoG1.3 GPoG1.4 GPoG1.5
 /STATISTICS=MEAN STDDEV MIN MAX.
