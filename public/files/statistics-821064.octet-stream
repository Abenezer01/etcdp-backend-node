GET
 FILE='C:\Users\EMI.DESKTOP-AOV0TBR.000\Desktop\SPSS V. 21\Exercise One19.sav'.
DATASET NAME DataSet1 WINDOW=FRONT.
FREQUENCIES VARIABLES=Age
 /STATISTICS=MEAN MEDIAN MODE
 /HISTOGRAM NORMAL
 /ORDER=ANALYSIS.
RECODE Age (Lowest thru 30=1) (31 thru 40=2) (41 thru Highest=3) INTO agegroup.
EXECUTE.
FREQUENCIES VARIABLES=agegroup
 /STATISTICS=MEDIAN MODE
 /BARCHART FREQ
 /ORDER=ANALYSIS.
FREQUENCIES VARIABLES=Mon.Inco
 /STATISTICS=STDDEV MINIMUM MAXIMUM MEAN MEDIAN
 /HISTOGRAM NORMAL
 /ORDER=ANALYSIS.
RECODE Mon.Inco (Lowest thru 1000=1) (1001 thru 2000=2) (2001 thru 3000=3) (3001 thru Highest=4) INTO newincome.
VARIABLE LABELS  newincome '1'.
EXECUTE.
FREQUENCIES VARIABLES=newincome
 /STATISTICS=STDDEV MINIMUM MAXIMUM MEAN MEDIAN
 /HISTOGRAM NORMAL
 /ORDER=ANALYSIS.
FREQUENCIES VARIABLES=newincome
 /STATISTICS=STDDEV MINIMUM MAXIMUM MEAN MEDIAN
 /PIECHART FREQ
