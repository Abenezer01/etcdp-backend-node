\pard\li1997\ri3242\sb220\sl278\slmult0\qj\tx2570\cf1\expndtw-8\b\f0\fs20 UNITY AND COMMUNITY \cf0\expndtw0\b0\f1\fs22\line\cf1\f0\fs20\tab\expndtw-8\b IN TIIE BODY\cf0\expndtw0\b0\f1\fs22\par

